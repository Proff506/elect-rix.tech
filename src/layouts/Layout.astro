---
import '../styles/global.css';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import { ui, useTranslations, type Lang } from '../i18n/translations';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  lang?: Lang;
}

const siteUrl = 'https://elect-rix.tech';
const { title, description = 'Protect your data. Even when the lights go out. Resilient, private, verifiable — built in, not bolted on.', ogImage = siteUrl + '/og-default.png', lang = 'en' } = Astro.props;

const t = useTranslations(lang);
const pathname = Astro.url.pathname;

const otherLang: Lang = lang === 'en' ? 'fr' : 'en';
let otherPath: string;
if (lang === 'en') {
  otherPath = '/fr' + pathname;
} else {
  otherPath = pathname.replace(/^\/fr/, '') || '/';
}

const navItems = [
  { label: t('nav.home'), href: '/' },
  { label: t('nav.report'), href: '/hyperscaler-audit' },
  { label: t('nav.about'), href: '/about' },
  { label: t('nav.trust'), href: '/trust' },
  { label: t('nav.safety'), href: '/safety' },
  { label: t('nav.lab'), href: '/lab' },
  { label: t('nav.contact'), href: '/contact' },
];

// For French pages, prepend /fr to priority pages that have translations
const frenchPages = new Set(['/', '/trust', '/safety']);
const resolvedNav = navItems.map(item => {
  if (lang === 'fr' && frenchPages.has(item.href)) {
    return { ...item, href: '/fr' + item.href };
  }
  return item;
});
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="elect-rix.tech" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Hreflang -->
    <link rel="alternate" hreflang="en" href={siteUrl + (lang === 'en' ? pathname : otherPath)} />
    <link rel="alternate" hreflang="fr" href={siteUrl + (lang === 'fr' ? pathname : otherPath)} />
    <link rel="alternate" hreflang="x-default" href={siteUrl + (lang === 'en' ? pathname : otherPath)} />

    <title>{title}</title>
    <link rel="icon" type="image/png" sizes="16x16" href="/brand/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/brand/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="64x64" href="/brand/favicon-64x64.png" />
    <link rel="apple-touch-icon" sizes="256x256" href="/brand/icon-256x256.png" />
  </head>
  <body class="antialiased">
    <nav class="fixed top-0 w-full z-50 border-b border-border bg-primary/80 backdrop-blur-md">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 h-16 flex items-center gap-4">
        <a href={lang === 'fr' ? '/fr/' : '/'} class="shrink-0 flex items-center gap-2 text-lg sm:text-xl font-bold tracking-tight text-accent-bright" aria-label="elect-rix.tech home">
          <img src="/brand/vault-door.svg" alt="" class="h-8 w-8 rounded-full" loading="eager" />
          <span class="hidden sm:inline">elect-rix.tech</span>
        </a>
        <div class="ml-auto hidden lg:flex gap-6 text-sm font-medium items-center whitespace-nowrap">
          {resolvedNav.map(item => (
            <a href={item.href} class="text-text-muted hover:text-text transition-colors">{item.label}</a>
          ))}
          <LanguageSwitcher lang={lang} pathname={pathname} />
        </div>
        <div class="ml-auto flex lg:hidden items-center gap-2 text-sm font-medium whitespace-nowrap">
          <a href="/hyperscaler-audit" class="inline-flex px-3 py-1.5 rounded-md border border-accent/40 text-accent-bright hover:bg-accent/10 transition-colors">Report</a>
          <a href="/contact" class="hidden min-[340px]:inline-flex px-2.5 py-1.5 rounded-md text-text-muted hover:text-text transition-colors">{t('nav.contact')}</a>
        </div>
      </div>
    </nav>

    <main class="pt-16 min-h-screen">
      <slot />
    </main>

    <footer class="border-t border-border py-8 mt-20">
      <div class="max-w-4xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-text-muted">
        <span>{t('footer.rights').replace('{year}', String(new Date().getFullYear()))}</span>
        <span>{t('footer.tagline')}</span>
      </div>
    </footer>
  </body>
</html>
