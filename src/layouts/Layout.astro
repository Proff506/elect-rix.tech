---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const siteUrl = 'https://elect-rix.tech';
const { title, description = 'Protect your data. Even when the lights go out. Resilient, private, verifiable — built in, not bolted on.', ogImage = siteUrl + '/og-default.png' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="elect-rix.tech" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body class="antialiased">
    <nav class="fixed top-0 w-full z-50 border-b border-border bg-primary/80 backdrop-blur-md">
      <div class="max-w-4xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href="/" class="text-xl font-bold tracking-tight text-accent-bright">elect-rix.tech</a>
        <div class="flex gap-6 text-sm font-medium">
          <a href="/" class="text-text-muted hover:text-text transition-colors">Home</a>
          <a href="/builds" class="text-text-muted hover:text-text transition-colors">Builds</a>
          <a href="/blog" class="text-text-muted hover:text-text transition-colors">Blog</a>
          <a href="/about" class="text-text-muted hover:text-text transition-colors">About</a>
          <a href="/trust" class="text-text-muted hover:text-text transition-colors">Trust</a>
          <a href="/safety" class="text-text-muted hover:text-text transition-colors">Safety</a>
          <a href="/lab" class="text-text-muted hover:text-text transition-colors">Lab</a>
          <a href="/contact" class="text-text-muted hover:text-text transition-colors">Contact</a>
        </div>
      </div>
    </nav>

    <main class="pt-16 min-h-screen">
      <slot />
    </main>

    <footer class="border-t border-border py-8 mt-20">
      <div class="max-w-4xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-text-muted">
        <span>© {new Date().getFullYear()} elect-rix.tech</span>
        <span>Resilience, privacy, trust — built in, not bolted on.</span>
      </div>
    </footer>
  </body>
</html>