---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Message Received — elect-rix.tech" description="Thank you for reaching out. We will respond within one business day.">
  <section class="relative overflow-hidden">
    <div class="max-w-2xl mx-auto px-6 pt-32 pb-20 text-center">
      <div class="w-16 h-16 rounded-full bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center mx-auto mb-8">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-400"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
      </div>
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight leading-[1.1] mb-6">
        Message received.
      </h1>
      <p class="text-lg text-text-muted max-w-lg mx-auto leading-relaxed mb-8">
        Thank you for reaching out. We will respond within one business day. In the meantime, your data is safe where it belongs — on your own hardware.
      </p>
      <a href="/" class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-accent text-white font-semibold hover:bg-accent-bright transition-colors">
        Back to Home
      </a>
    </div>
  </section>
</Layout>