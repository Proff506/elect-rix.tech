---
import Layout from '../../layouts/Layout.astro';
import { useTranslations } from '../../i18n/translations';

const t = useTranslations('fr');

const services = [
  {
    title: t('home.services.resilience.title'),
    description: t('home.services.resilience.description'),
    icon: '🛡️',
  },
  {
    title: t('home.services.privacy.title'),
    description: t('home.services.privacy.description'),
    icon: '🔒',
  },
  {
    title: t('home.services.trust.title'),
    description: t('home.services.trust.description'),
    icon: '✅',
  },
  {
    title: t('home.services.integration.title'),
    description: t('home.services.integration.description'),
    icon: '🎯',
  },
];
---

<Layout
  lang="fr"
  title="elect-rix.tech — Protégez vos données. Même quand les lumières s'éteignent."
  description="Protégez vos données. Même quand les lumières s'éteignent. Systèmes d'IA résilients, privés et vérifiables. Intégrité, loyauté, honnêteté — intégrées, pas ajoutées."
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="max-w-5xl mx-auto px-6 pt-32 pb-20 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-accent/10 text-accent-bright text-sm font-medium mb-8 border border-accent/20">
        <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
        {t('available')}
      </div>
      <h1 class="text-5xl sm:text-6xl font-extrabold tracking-tight leading-[1.1] mb-6">
        {t('home.heroTitle')}<br />
        <span class="text-accent-bright">{t('home.heroSubtitle')}</span>
      </h1>
      <p class="text-lg sm:text-xl text-text-muted max-w-2xl mx-auto leading-relaxed mb-10">
        {t('home.heroBody')}
      </p>
      <div class="flex justify-center">
        <a href="/contact" class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-accent text-white font-semibold hover:bg-accent-bright transition-colors">
          {t('cta.getInTouch')}
        </a>
      </div>
      <div class="mt-12 rounded-xl border border-border overflow-hidden max-w-3xl mx-auto">
        <img src="/resilience-offline-shield.png" alt="Système résilient protégé du chaos réseau" class="w-full h-auto" />
      </div>
    </div>
  </section>

  <!-- About Preview -->
  <section class="border-y border-border bg-surface/50">
    <div class="max-w-5xl mx-auto px-6 py-20">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold tracking-tight mb-4">{t('home.builtDifferent')}</h2>
          <div class="space-y-4 text-text-muted leading-relaxed">
            <p>{t('home.builtDifferentBody1')}</p>
            <p>{t('home.builtDifferentBody2')}</p>
          </div>
          <a href="/about" class="inline-flex items-center gap-2 text-accent-bright font-medium mt-6 hover:underline">
            {t('cta.whyItMatters')}
          </a>
        </div>
        <div class="p-6 rounded-xl border border-border bg-primary">
          <div class="space-y-4">
            <div class="flex items-center justify-between">
              <span class="text-text-muted">LLM local</span>
              <span class="text-accent-bright font-semibold">Ollama</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-text-muted">Plateforme conteneurs</span>
              <span class="text-accent-bright font-semibold">Docker</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-text-muted">Orchestration</span>
              <span class="text-accent-bright font-semibold">Docker</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-text-muted">Système d'exploitation</span>
              <span class="text-accent-bright font-semibold">Pop!_OS</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-text-muted">GPU</span>
              <span class="text-accent-bright font-semibold">RTX 5070 Ti</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-text-muted">Processeur</span>
              <span class="text-accent-bright font-semibold">Core i9 14900K</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-20">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">{t('home.whatIDo')}</h2>
        <p class="text-text-muted text-lg max-w-2xl mx-auto">
          {t('home.whatIDoBody')}
        </p>
      </div>
      <div class="rounded-xl border border-border overflow-hidden max-w-3xl mx-auto mb-12">
        <img src="/duo-cyber-industrial-hero.png" alt="Infrastructure IA — traitement central avec circuits distribués" class="w-full h-auto" />
      </div>
      <div class="grid sm:grid-cols-2 gap-6">
        {services.map((service) => (
          <div class="p-6 rounded-xl border border-border bg-primary hover:border-accent/30 transition-colors group">
            <div class="w-12 h-12 rounded-lg bg-accent/10 flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-transform">
              {service.icon}
            </div>
            <h3 class="text-xl font-semibold mb-3">{service.title}</h3>
            <p class="text-text-muted leading-relaxed">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-y border-border bg-surface/50 py-20">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-6">
        {t('home.startAudit')}
      </h2>
      <p class="text-text-muted text-lg mb-10 leading-relaxed">
        {t('home.startAuditBody')}
      </p>
      <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 rounded-lg bg-accent text-white font-semibold hover:bg-accent-bright transition-colors text-lg">
        {t('cta.getInTouch')}
      </a>
    </div>
  </section>
</Layout>
