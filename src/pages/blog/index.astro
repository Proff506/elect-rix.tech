---
import Layout from '../../layouts/Layout.astro';
const posts = Object.values(import.meta.glob('../../content/posts/*.md', { eager: true })).sort((a: any, b: any) => new Date(b.frontmatter.pubDate).getTime() - new Date(a.frontmatter.pubDate).getTime()
);
const tags = [...new Set(posts.flatMap((p: any) => p.frontmatter.tags || []))].sort();
---

<Layout title="Blog — elect-rix.tech" description="Thoughts, builds, and experiments from the Workstation Duo.">
  <section class="max-w-4xl mx-auto px-6 pt-24 pb-16">
    <header class="mb-10">
      <h1 class="text-4xl font-extrabold tracking-tight mb-3">Blog</h1>
      <p class="text-lg text-text-muted">Thoughts, builds, and experiments from the Workstation Duo.</p>
    </header>

    {tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-8">
        <span class="text-sm text-text-muted">Filter:</span>
        {tags.map((tag) => (
          <span class="text-xs px-2.5 py-0.5 rounded-full bg-accent/10 text-accent-bright border border-accent/20">{tag}</span>
        ))}
      </div>
    )}

    <div class="space-y-6">
      {posts.map((post: any) => (
        <article class="group p-6 rounded-xl border border-border bg-surface hover:bg-surface-light transition-colors">
          <a href={`/blog/${post.frontmatter.slug || post.file.split('/').pop().replace('.md','')}`} class="block">
            <time class="text-sm text-text-muted">
              {new Date(post.frontmatter.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <h2 class="text-xl font-semibold mt-2 group-hover:text-accent-bright transition-colors">{post.frontmatter.title}</h2>
            <p class="text-text-muted mt-2 leading-relaxed">{post.frontmatter.description}</p>
            <div class="flex flex-wrap gap-2 mt-4">
              {(post.frontmatter.tags || []).map((tag: string) => (
                <span class="px-2.5 py-0.5 text-xs font-medium rounded-full bg-accent/10 text-accent-bright">{tag}</span>
              ))}
            </div>
          </a>
        </article>
      ))}
    </div>
  </section>
</Layout>
