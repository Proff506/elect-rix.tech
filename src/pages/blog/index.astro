---
import Layout from '../../layouts/Layout.astro';
const allPosts = Object.values(import.meta.glob('../../content/posts/*.md', { eager: true })).sort((a: any, b: any) => new Date(b.frontmatter.pubDate).getTime() - new Date(a.frontmatter.pubDate).getTime()
);
const posts = allPosts.filter((p: any) => !p.frontmatter.draft);
const categories = [...new Set(posts.map((p: any) => p.frontmatter.category || 'Engineering'))].sort();
const tags = [...new Set(posts.flatMap((p: any) => p.frontmatter.tags || []))].sort();

// Category colors
type CategoryKey = string;
const categoryStyles: Record<CategoryKey, string> = {
  'Engineering': 'bg-accent/10 text-accent-bright border-accent/20',
};
const getCategoryStyle = (cat: string) => categoryStyles[cat] || categoryStyles['Engineering'];

// Track selected category via query param
const selectedCategory = Astro.url.searchParams.get('category') || 'All';
const filteredPosts = selectedCategory === 'All'
  ? posts
  : posts.filter((p: any) => (p.frontmatter.category || 'Engineering') === selectedCategory);
---

<Layout title="Blog — elect-rix.tech" description="Protect your data. Even when the lights go out. Thoughts, builds, and experiments from the lab.">
  <section class="max-w-4xl mx-auto px-6 pt-24 pb-16">
    <header class="mb-10">
      <h1 class="text-4xl font-extrabold tracking-tight mb-3">Blog</h1>
      <p class="text-lg text-text-muted">Thoughts, builds, and experiments from the lab.</p>
    </header>

    <!-- Category Filter -->
    {categories.length > 0 && (
      <div class="flex flex-wrap items-center gap-2 mb-8">
        <span class="text-sm text-text-muted mr-1">Category:</span>
        <a href="/blog" class={`text-xs px-3 py-1 rounded-full font-medium border transition-colors ${selectedCategory === 'All' ? 'bg-accent text-white border-accent' : 'bg-surface text-text-muted border-border hover:border-accent/40'}`}>All</a>
        {categories.map((cat) => (
          <a href={`/blog?category=${encodeURIComponent(cat)}`} class={`text-xs px-3 py-1 rounded-full font-medium border transition-colors ${selectedCategory === cat ? 'bg-accent text-white border-accent' : 'bg-surface text-text-muted border-border hover:border-accent/40'}`}>{cat}</a>
        ))}
      </div>
    )}

    {tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-8">
        <span class="text-sm text-text-muted">Tags:</span>
        {tags.map((tag) => (
          <span class="text-xs px-2.5 py-0.5 rounded-full bg-accent/10 text-accent-bright border border-accent/20">{tag}</span>
        ))}
      </div>
    )}

    <div class="space-y-6">
      {filteredPosts.map((post: any) => (
        <article class="group p-6 rounded-xl border border-border bg-surface hover:bg-surface-light transition-colors">
          <a href={`/blog/${post.frontmatter.slug || post.file.split('/').pop().replace('.md','')}`} class="block">
            <time class="text-sm text-text-muted block mb-2">
              {new Date(post.frontmatter.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <span class={`inline-block text-xs px-2.5 py-0.5 rounded-full font-medium border mb-2 ${getCategoryStyle(post.frontmatter.category || 'Engineering')}`}>
              {post.frontmatter.category || 'Engineering'}
            </span>
            <h2 class="text-xl font-semibold group-hover:text-accent-bright transition-colors">{post.frontmatter.title}</h2>
            <p class="text-text-muted mt-3 leading-relaxed">{post.frontmatter.description}</p>
            <div class="flex flex-wrap gap-2 mt-4">
              {(post.frontmatter.tags || []).map((tag: string) => (
                <span class="px-2.5 py-0.5 text-xs font-medium rounded-full bg-accent/10 text-accent-bright">{tag}</span>
              ))}
            </div>
          </a>
        </article>
      ))}

      {filteredPosts.length === 0 && (
        <div class="text-center py-16 text-text-muted">
          <p>No posts in this category yet.</p>
          <a href="/blog" class="text-accent-bright hover:underline mt-2 inline-block">View all posts →</a>
        </div>
      )}
    </div>
  </section>
</Layout>
