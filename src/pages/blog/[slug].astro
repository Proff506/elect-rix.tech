---
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
  const posts = Object.entries(import.meta.glob('../../content/posts/*.md', { eager: true }));
  return posts.map(([path, post]: [string, any]) => {
    const slug = path.split('/').pop().replace('.md', '');
    return { params: { slug }, props: { post, slug } };
  });
}

const { post, slug } = Astro.props;
const { Content } = post;

const category = post.frontmatter.category || 'Engineering';
const categoryClass = 'bg-accent/10 text-accent-bright border-accent/20';
---

<Layout title={`${post.frontmatter.title} — elect-rix.tech`} description={post.frontmatter.description}>
  <article class="max-w-3xl mx-auto px-6 pt-24 pb-16">
    <header class="mb-10">
      <div class="flex items-center gap-3 mb-2">
        <time class="text-sm text-text-muted">
          {new Date(post.frontmatter.pubDate || Date.now()).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        {category && (
          <span class={`text-xs px-2.5 py-0.5 rounded-full font-medium border ${categoryClass}`}>
            {category}
          </span>
        )}
      </div>
      <h1 class="text-4xl font-extrabold tracking-tight mt-3 mb-4">{post.frontmatter.title}</h1>
      <p class="text-lg text-text-muted leading-relaxed">{post.frontmatter.description}</p>
      <div class="flex flex-wrap gap-2 mt-5">
        {(post.frontmatter.tags || []).map((tag: string) => (
          <span class="px-2.5 py-0.5 text-xs font-medium rounded-full bg-accent/10 text-accent-bright">{tag}</span>
        ))}
      </div>
    </header>

    <div class="prose prose-invert max-w-none">
      <Content />
    </div>

    <div class="mt-12 pt-8 border-t border-border">
      <a href="/blog" class="text-accent-bright font-medium hover:underline">← All Posts</a>
    </div>
  </article>
</Layout>
