---
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
  const posts = Object.entries(import.meta.glob('../../content/posts/*.md', { eager: true }));
  return posts.map(([path, post]: [string, any]) => {
    const slug = path.split('/').pop().replace('.md', '');
    return {
      params: { slug },
      props: { post, slug },
    };
  });
}

const { post, slug } = Astro.props;

// @ts-ignore
const { Content } = post;
---

<Layout title={`${post.frontmatter.title} — elect-rix.tech`} description={post.frontmatter.description}>
  <article class="max-w-3xl mx-auto px-6 pt-24 pb-16">
    <header class="mb-10">
      <time class="text-sm text-text-muted">
        {new Date(post.frontmatter.pubDate || Date.now()).toLocaleDateString('en-US', {
          year: 'numeric', month: 'long', day: 'numeric'
        })}
      </time>
      <h1 class="text-4xl font-extrabold tracking-tight mt-3 mb-4">{post.frontmatter.title}</h1>
      <p class="text-lg text-text-muted leading-relaxed">{post.frontmatter.description}</p>
      {post.frontmatter.heroImage && (
        <img src={post.frontmatter.heroImage} alt={post.frontmatter.title} class="mt-8 rounded-xl w-full" />
      )}
    </header>

    <div class="prose prose-invert max-w-none">
      <Content />
    </div>

    <footer class="border-t border-border mt-16 pt-8">
      <a href="/blog" class="text-accent-bright hover:text-accent transition-colors text-sm font-medium">
        ← All posts
      </a>
    </footer>
  </article>
</Layout>