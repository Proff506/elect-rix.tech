---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

const services = [
  {
    title: 'Resilience Engineering',
    description: 'AI systems that run when the cloud doesn\'t. Offline-capable agents, local inference, and fallback architectures that keep working under failure.',
    icon: '🛡️',
  },
  {
    title: 'Privacy Architecture',
    description: 'Zero telemetry by design, not by configuration. Your data stays on your hardware. Audit every packet. Prove nothing leaves.',
    icon: '🔒',
  },
  {
    title: 'Verifiable Trust',
    description: 'Trust measured in logs, not promises. Inspectable behavior, transparent operations, and proof that your systems do exactly what they claim.',
    icon: '✅',
  },
  {
    title: 'Integration & Consulting',
    description: 'From audit to deployment. Find the gaps in your AI stack — cloud dependency, telemetry leaks, compliance risks — and close them by design.',
    icon: '🎯',
  },
];

const builds = [
  {
    name: 'RixBot',
    category: 'AI Agent Platform',
    description: 'Private AI chatbot with full R\u0026D knowledge base access. Demo mode with zero cloud dependency, live mode via Ollama endpoint.',
    stack: 'Astro · JS · RAG',
    status: 'Live',
  },
  {
    name: 'Hermes Agent Bot',
    category: 'AI Agent Platform',
    description: 'Autonomous AI assistant deployed on Telegram. Manages coding tasks, research, and DevOps — 24/7.',
    stack: 'Python · Telethon · Ollama · Docker',
    status: 'Running',
  },
  {
    name: 'elect-rix.tech',
    category: 'Personal Site',
    description: 'This site — Astro, Bun, Tailwind. Built locally, deployed to Cloudflare Pages, generated with AI assistance.',
    stack: 'Astro · Bun · Tailwind',
    status: 'Live',
  },
  {
    name: 'Workstation Duo',
    category: 'Lab Infrastructure',
    description: 'Two-machine setup: local LLM inference, distributed builds, GPU compute, and self-hosted services.',
    stack: 'Pop!_OS · Ollama · Docker',
    status: 'Active',
  },
];

const posts = Object.values(import.meta.glob('../content/posts/*.md', { eager: true })).slice(0, 3);
---

<Layout title="elect-rix.tech — AI That Works When the Cloud Doesn't" description="Resilient, private, verifiable AI systems. Integrity, loyalty, honesty — built in, not bolted on.">
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="max-w-5xl mx-auto px-6 pt-32 pb-20 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-accent/10 text-accent-bright text-sm font-medium mb-8 border border-accent/20">
        <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
        Available for projects
      </div>
      <h1 class="text-5xl sm:text-6xl font-extrabold tracking-tight leading-[1.1] mb-6">
        Make it work.<br />
        <span class="text-accent-bright">Trust you can verify.</span>
      </h1>
      <p class="text-lg sm:text-xl text-text-muted max-w-2xl mx-auto leading-relaxed mb-10">
        When the cloud drops, your systems shouldn't. When the audit comes, your data should be yours to account for. AI that works offline, leaks nothing, and proves it — built in, not bolted on.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/builds" class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-accent text-white font-semibold hover:bg-accent-bright transition-colors">
          See Builds →
        </a>
        <a href="mailto:hello@elect-rix.tech" class="inline-flex items-center justify-center px-6 py-3 rounded-lg border border-border text-text font-semibold hover:bg-surface-light transition-colors">
          Get in Touch
        </a>
      </div>
    </div>
  </section>

  <!-- About Preview -->
  <section class="border-y border-border bg-surface/50">
    <div class="max-w-5xl mx-auto px-6 py-20">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold tracking-tight mb-4">Built Different</h2>
          <div class="space-y-4 text-text-muted leading-relaxed">
            <p>
              One builder. Two workstations. Local LLM inference on real hardware, not a cloud API with a quota. Everything is self-hosted, private, and runs offline.
            </p>
            <p>
              The AI industry builds for connectivity. I build for what happens when it fails. Resilience isn't a feature you add — it's architecture you commit to. Your data doesn't leave the box. Your systems don't drop when the cloud does. Your trust is verifiable, not taken on faith.
            </p>
          </div>
          <a href="/about" class="inline-flex items-center gap-2 text-accent-bright font-medium mt-6 hover:underline">
            Why it matters →
          </a>
        </div>
        <div class="p-6 rounded-xl border border-border bg-primary">
          <div class="space-y-4">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center text-accent-bright">🖥️</div>
              <div>
                <div class="font-medium">Primary Workstation</div>
                <div class="text-sm text-text-muted">Intel i9-14900K · RTX 5070 Ti · 32GB DDR5 · Pop!_OS</div>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center text-accent-bright">🖥️</div>
              <div>
                <div class="font-medium">Secondary Workstation</div>
                <div class="text-sm text-text-muted">Intel i7-12700KF · Dual RX 9060 XT · 32GB DDR4 · Linux Mint</div>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center text-accent-bright">🧠</div>
              <div>
                <div class="font-medium">Local AI Stack</div>
                <div class="text-sm text-text-muted">Ollama · Qwen · Granite · Phi · Nemotron</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="max-w-5xl mx-auto px-6 py-20">
    <div class="text-center mb-14">
      <h2 class="text-3xl font-bold tracking-tight mb-3">What I Build</h2>
      <p class="text-text-muted max-w-xl mx-auto">Resilient, private, verifiable — not features. Architecture.</p>
    </div>
    <div class="grid sm:grid-cols-2 gap-6">
      {services.map((s) => (
        <div class="group p-6 rounded-xl border border-border bg-surface hover:bg-surface-light transition-all hover:-translate-y-0.5">
          <div class="text-3xl mb-4">{s.icon}</div>
          <h3 class="text-lg font-semibold mb-2">{s.title}</h3>
          <p class="text-text-muted leading-relaxed text-sm">{s.description}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Featured Builds -->
  <section class="border-y border-border bg-surface/50">
    <div class="max-w-5xl mx-auto px-6 py-20">
      <div class="flex items-end justify-between mb-10">
        <div>
          <h2 class="text-3xl font-bold tracking-tight mb-2">Featured Builds</h2>
          <p class="text-text-muted">Projects shipping from the Workstation Duo.</p>
        </div>
        <a href="/builds" class="text-sm text-accent-bright font-medium hover:underline hidden sm:block">View All →</a>
      </div>
      <div class="grid sm:grid-cols-3 gap-5">
        {builds.map((b) => (
          <div class="p-5 rounded-xl border border-border bg-primary hover:bg-surface-light transition-all group">
            <div class="flex items-center justify-between mb-3">
              <span class="text-xs font-medium px-2.5 py-0.5 rounded-full bg-accent/10 text-accent-bright">{b.category}</span>
              <span class="text-xs text-emerald-400 font-medium flex items-center gap-1">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>{b.status}
              </span>
            </div>
            <h3 class="font-semibold mb-2 group-hover:text-accent-bright transition-colors">{b.name}</h3>
            <p class="text-sm text-text-muted leading-relaxed mb-4">{b.description}</p>
            <div class="text-xs text-text-muted font-mono">{b.stack}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Latest Posts -->
  <section class="max-w-5xl mx-auto px-6 py-20">
    <div class="flex items-end justify-between mb-10">
      <div>
        <h2 class="text-3xl font-bold tracking-tight mb-2">From the Blog</h2>
        <p class="text-text-muted">Experiments, tutorials, and lessons learned.</p>
      </div>
      <a href="/blog" class="text-sm text-accent-bright font-medium hover:underline hidden sm:block">All Posts →</a>
    </div>
    <div class="space-y-4">
      {posts.map((post: any) => (
        <article class="group p-5 rounded-xl border border-border bg-surface hover:bg-surface-light transition-colors">
          <a href={`/blog/${post.frontmatter.slug || post.file.split('/').pop().replace('.md','')}`} class="flex flex-col sm:flex-row sm:items-center gap-4">
            <time class="text-sm text-text-muted whitespace-nowrap w-32 shrink-0">
              {new Date(post.frontmatter.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2">
                <span class={`text-xs px-2 py-0.5 rounded-full font-medium ${['From The Basement', 'Commentary'].includes(post.frontmatter.category || 'Engineering') ? 'bg-purple-500/10 text-purple-300 border border-purple-500/20' : 'bg-accent/10 text-accent-bright border border-accent/20'}`}>
                  {post.frontmatter.category || 'Engineering'}
                </span>
              </div>
              <h3 class="font-semibold group-hover:text-accent-bright transition-colors truncate mt-1">{post.frontmatter.title}</h3>
              <p class="text-sm text-text-muted truncate">{post.frontmatter.description}</p>
            </div>
            <span class="text-accent-bright opacity-0 group-hover:opacity-100 transition-opacity shrink-0">→</span>
          </a>
        </article>
      ))}
    </div>
  </section>
</Layout>
