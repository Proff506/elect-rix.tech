---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    title: 'Resilience Engineering',
    description: 'AI systems that run when the cloud doesn\'t. Protected even when the lights go out.',
    icon: '🛡️',
  },
  {
    title: 'Privacy Architecture',
    description: 'Telemetry minimized and made visible by design, not hidden behind policy. Keep sensitive data on owned hardware. Audit the flows. Prove the boundary.',
    icon: '🔒',
  },
  {
    title: 'Verifiable Trust',
    description: 'Trust measured in logs, not promises. Inspectable behavior, transparent operations, and proof that your systems do exactly what they claim.',
    icon: '✅',
  },
  {
    title: 'Integration & Consulting',
    description: 'From audit to deployment. Find the gaps in your AI stack — cloud dependency, telemetry leaks, compliance risks — and close them by design.',
    icon: '🎯',
  },
];
---

<Layout title="elect-rix.tech — Local Vault for Operations & Data Sovereignty" description="Local Vault keeps your AI, files, and client conversations inside your New Brunswick office. RixBot included. Free 20-minute phone audit.">
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 pt-24 sm:pt-32 pb-16 sm:pb-20 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-accent/10 text-accent-bright text-sm font-medium mb-8 border border-accent/20">
        <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
        Available for projects
      </div>
      <h1 class="text-[2rem] min-[360px]:text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-[1.08] mb-6">
        Operations and data sovereignty<br class="hidden sm:block" />
        <span class="text-accent-bright">for New Brunswick offices.</span>
      </h1>
      <p class="text-lg sm:text-xl text-text-muted max-w-2xl mx-auto leading-relaxed mb-10">
        Local Vault keeps your AI, files, and client conversations inside your building — not in a hyperscaler. RixBot, the included local agent interface, works even when the internet doesn't.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-3 sm:gap-4">
        <a href="/contact" class="inline-flex w-full sm:w-auto items-center justify-center px-5 sm:px-6 py-3 rounded-lg bg-accent text-white font-semibold hover:bg-accent-bright transition-colors">
          Book a Free 20-Minute Phone Audit
        </a>
        <a href="/local-vault" class="inline-flex w-full sm:w-auto items-center justify-center px-5 sm:px-6 py-3 rounded-lg border border-border text-text font-semibold hover:border-accent/60 hover:text-accent-bright transition-colors">
          See How Local Vault Works
        </a>
      </div>
      <div class="mt-10 sm:mt-12 rounded-xl border border-border overflow-hidden max-w-3xl mx-auto shadow-2xl shadow-accent/5">
        <img src="/resilience-offline-shield.png" alt="Resilient system shielded from network chaos" class="w-full h-auto" />
      </div>
    </div>
  </section>

  <!-- About Preview -->
  <section class="border-y border-border bg-surface/50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-16 sm:py-20">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold tracking-tight mb-4">Local Vault, Built In</h2>
          <div class="space-y-4 text-text-muted leading-relaxed">
            <p>
              Local Vault is a self-contained AI and data system for offices that cannot send client files, patient records, or privileged conversations to the cloud. It runs on hardware you own, in your building, on your network.
            </p>
            <p>
              RixBot is the included agent interface — like Siri on an iPhone, it comes with the vault. Staff can ask questions, summarize documents, and automate work without data leaving the room. When the internet drops, the vault keeps working.
            </p>
          </div>
          <a href="/local-vault" class="inline-flex items-center gap-2 text-accent-bright font-medium mt-6 hover:underline">
            What's inside the vault →
          </a>
        </div>
        <div class="p-4 sm:p-6 rounded-xl border border-border bg-primary">
          <div class="space-y-4">
            <div class="flex flex-col min-[380px]:flex-row min-[380px]:items-center min-[380px]:justify-between gap-1">
              <span class="text-text-muted">Local LLM</span>
              <span class="text-accent-bright font-semibold min-[380px]:text-right">Ollama</span>
            </div>
            <div class="flex flex-col min-[380px]:flex-row min-[380px]:items-center min-[380px]:justify-between gap-1">
              <span class="text-text-muted">Container Platform</span>
              <span class="text-accent-bright font-semibold min-[380px]:text-right">Docker</span>
            </div>
            <div class="flex flex-col min-[380px]:flex-row min-[380px]:items-center min-[380px]:justify-between gap-1">
              <span class="text-text-muted">Orchestration</span>
              <span class="text-accent-bright font-semibold min-[380px]:text-right">Docker</span>
            </div>
            <div class="flex flex-col min-[380px]:flex-row min-[380px]:items-center min-[380px]:justify-between gap-1">
              <span class="text-text-muted">Operating System</span>
              <span class="text-accent-bright font-semibold min-[380px]:text-right">Pop!_OS</span>
            </div>
            <div class="flex flex-col min-[380px]:flex-row min-[380px]:items-center min-[380px]:justify-between gap-1">
              <span class="text-text-muted">GPU</span>
              <span class="text-accent-bright font-semibold min-[380px]:text-right">RTX 5070 Ti</span>
            </div>
            <div class="flex flex-col min-[380px]:flex-row min-[380px]:items-center min-[380px]:justify-between gap-1">
              <span class="text-text-muted">Processor</span>
              <span class="text-accent-bright font-semibold min-[380px]:text-right">Core i9 14900K</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">What I Do</h2>
        <p class="text-text-muted text-lg max-w-2xl mx-auto">
          Not features. Principles. Every engagement starts with these four commitments.
        </p>
      </div>
      <div class="rounded-xl border border-border overflow-hidden max-w-3xl mx-auto mb-12">
        <img src="/duo-cyber-industrial-hero.png" alt="AI infrastructure brain — central processing with distributed circuits" class="w-full h-auto" />
      </div>
      <div class="grid sm:grid-cols-2 gap-6">
        {services.map((service) => (
          <div class="p-5 sm:p-6 rounded-xl border border-border bg-primary hover:border-accent/30 transition-colors group">
            <div class="w-12 h-12 rounded-lg bg-accent/10 flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-transform">
              {service.icon}
            </div>
            <h3 class="text-xl font-semibold mb-3">{service.title}</h3>
            <p class="text-text-muted leading-relaxed">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-y border-border bg-surface/50 py-20">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-6">
        Not sure if Local Vault fits your office?
      </h2>
      <p class="text-text-muted text-lg mb-10 leading-relaxed">
        Start with a free 20-minute phone audit. I'll ask about your current AI tools, where your data goes, and whether a Local Vault deployment makes sense. No sales pressure — just a clear yes or no.
      </p>
      <a href="/contact" class="inline-flex w-full sm:w-auto items-center justify-center px-6 sm:px-8 py-4 rounded-lg bg-accent text-white font-semibold hover:bg-accent-bright transition-colors text-lg">
        Book a Free Phone Audit
      </a>
    </div>
  </section>
</Layout>
