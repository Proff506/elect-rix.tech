---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    title: 'Resilience Engineering',
    description: 'AI systems that run when the cloud doesn\'t. Protected even when the lights go out.',
    icon: '🛡️',
  },
  {
    title: 'Privacy Architecture',
    description: 'Zero telemetry by design, not by configuration. Your data stays on your hardware. Audit every packet. Prove nothing leaves.',
    icon: '🔒',
  },
  {
    title: 'Verifiable Trust',
    description: 'Trust measured in logs, not promises. Inspectable behavior, transparent operations, and proof that your systems do exactly what they claim.',
    icon: '✅',
  },
  {
    title: 'Integration & Consulting',
    description: 'From audit to deployment. Find the gaps in your AI stack — cloud dependency, telemetry leaks, compliance risks — and close them by design.',
    icon: '🎯',
  },
];
---

<Layout title="elect-rix.tech — Protect Your Data. Even When the Lights Go Out." description="Protect your data. Even when the lights go out. Resilient, private, verifiable AI systems. Integrity, loyalty, honesty — built in, not bolted on.">
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="max-w-5xl mx-auto px-6 pt-32 pb-20 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-accent/10 text-accent-bright text-sm font-medium mb-8 border border-accent/20">
        <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
        Available for projects
      </div>
      <h1 class="text-5xl sm:text-6xl font-extrabold tracking-tight leading-[1.1] mb-6">
        Make it work.<br />
        <span class="text-accent-bright">Trust you can verify.</span>
      </h1>
      <p class="text-lg sm:text-xl text-text-muted max-w-2xl mx-auto leading-relaxed mb-10">
        Protect your data. Even when the lights go out. When the cloud drops, your systems shouldn't. When the audit comes, your data should be yours to account for. AI that works offline, leaks nothing, and proves it — built in, not bolted on.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/builds" class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-accent text-white font-semibold hover:bg-accent-bright transition-colors">
          See Builds →
        </a>
        <a href="/contact" class="inline-flex items-center justify-center px-6 py-3 rounded-lg border border-border text-text font-semibold hover:bg-surface-light transition-colors">
          Get in Touch
        </a>
      </div>
      <div class="mt-12 rounded-xl border border-border overflow-hidden max-w-3xl mx-auto">
        <img src="/resilience-offline-shield.png" alt="Resilient system shielded from network chaos" class="w-full h-auto" />
      </div>
    </div>
  </section>

  <!-- About Preview -->
  <section class="border-y border-border bg-surface/50">
    <div class="max-w-5xl mx-auto px-6 py-20">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold tracking-tight mb-4">Built Different</h2>
          <div class="space-y-4 text-text-muted leading-relaxed">
            <p>
              One builder. Dedicated infrastructure. Local LLM inference on owned hardware, not a cloud API with a quota. Everything is self-hosted, private, and runs offline by architecture.
            </p>
            <p>
              The AI industry builds for connectivity. I build for what happens when it fails. Resilience isn't a feature you add — it's architecture you commit to. Your data doesn't leave the box. Your systems don't drop when the cloud does. Your trust is verifiable, not taken on faith.
            </p>
          </div>
          <a href="/about" class="inline-flex items-center gap-2 text-accent-bright font-medium mt-6 hover:underline">
            Why it matters →
          </a>
        </div>
        <div class="p-6 rounded-xl border border-border bg-primary">
          <div class="space-y-4">
            <div class="flex items-center justify-between">
              <span class="text-text-muted">Local LLM</span>
              <span class="text-accent-bright font-semibold">Ollama</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-text-muted">Container Platform</span>
              <span class="text-accent-bright font-semibold">Docker</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-text-muted">Orchestration</span>
              <span class="text-accent-bright font-semibold">Docker Swarm</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-text-muted">Operating System</span>
              <span class="text-accent-bright font-semibold">Pop!_OS</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-text-muted">GPU</span>
              <span class="text-accent-bright font-semibold">RTX 5070 Ti</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-text-muted">Processor</span>
              <span class="text-accent-bright font-semibold">Core i9 14900K</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-20">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">What I Do</h2>
        <p class="text-text-muted text-lg max-w-2xl mx-auto">
          Not features. Principles. Every engagement starts with these four commitments.
        </p>
      </div>
      <div class="rounded-xl border border-border overflow-hidden max-w-3xl mx-auto mb-12">
        <img src="/duo-cyber-industrial-hero.png" alt="AI infrastructure brain — central processing with distributed circuits" class="w-full h-auto" />
      </div>
      <div class="grid sm:grid-cols-2 gap-6">
        {services.map((service) => (
          <div class="p-6 rounded-xl border border-border bg-primary hover:border-accent/30 transition-colors group">
            <div class="w-12 h-12 rounded-lg bg-accent/10 flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-transform">
              {service.icon}
            </div>
            <h3 class="text-xl font-semibold mb-3">{service.title}</h3>
            <p class="text-text-muted leading-relaxed">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-y border-border bg-surface/50 py-20">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-6">
        Start with an audit, not an apology.
      </h2>
      <p class="text-text-muted text-lg mb-10 leading-relaxed">
        I help teams find the risks in their AI stack — cloud dependency, privacy leaks, compliance gaps — before a regulator, a breach, or a lawsuit does. If you already know you have a problem, we start there. If you want proof you don't, we find that too.
      </p>
      <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 rounded-lg bg-accent text-white font-semibold hover:bg-accent-bright transition-colors text-lg">
        Get in Touch
      </a>
    </div>
  </section>
</Layout>
