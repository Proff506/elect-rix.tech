---
import Layout from '../layouts/Layout.astro';

const builds = [
  {
    id: 'executive',
    name: 'Executive Configuration',
    variant: 'LANCOOL 217 — Black / Walnut',
    tagline: 'For law firms, government offices, and executive suites',
    accent: 'from-amber-900/20 to-stone-900/20',
    badge: 'Legal & Government',
    description:
      'The walnut wood front panel signals craftsmanship and permanence — not a gamer rig. Built for environments where solicitor-client privilege, FOIPOP compliance, and Protected A/B data residency are daily requirements. Sits on a desk or credenza without dominating the room.',
    specs: [
      { label: 'Chassis', value: 'Lian-Li LANCOOL 217 (Black/Walnut)' },
      { label: 'Form Factor', value: 'ATX mid-tower, 380mm GPU clearance' },
      { label: 'Target GPU', value: 'RTX 4090 / 5090 (all variants)' },
      { label: 'Cooling', value: '5 pre-installed PWM fans, 360mm AIO top mount' },
      { label: 'Mobo Support', value: 'ATX / mATX / ITX, back-connect ready' },
      { label: 'Certification', value: 'PPLP certified for professional use' },
      { label: 'Aesthetic', value: 'Dark wood accents, tempered glass, toolless access' },
    ],
    useCases: ['Law firms', 'Government offices', 'Executive suites', 'Boardroom deployments'],
    photoNote: 'Photography pending — owner has chassis in hand',
  },
  {
    id: 'clean',
    name: 'Clean Configuration',
    variant: 'LANCOOL 217 — White / Beech',
    tagline: 'For healthcare clinics, creative studios, and client-facing offices',
    accent: 'from-sky-900/20 to-stone-100/20',
    badge: 'Healthcare & Creative',
    description:
      'The white chassis with light beech wood accents fits bright, clinical environments. For healthcare practices building toward PHIPA, CIHI, and RED Toolkit expectations — or creative studios that need local AI without the visual language of a data centre.',
    specs: [
      { label: 'Chassis', value: 'Lian-Li LANCOOL 217 (White/Beech)' },
      { label: 'Form Factor', value: 'ATX mid-tower, 380mm GPU clearance' },
      { label: 'Target GPU', value: 'RTX 4090 / 5090 (all variants)' },
      { label: 'Cooling', value: '5 pre-installed PWM fans, 360mm AIO top mount' },
      { label: 'Mobo Support', value: 'ATX / mATX / ITX, back-connect ready' },
      { label: 'Certification', value: 'PPLP certified for professional use' },
      { label: 'Aesthetic', value: 'Light wood accents, white steel, tempered glass' },
    ],
    useCases: ['Healthcare clinics', 'Creative studios', 'Client-facing offices', 'Reception deployments'],
    photoNote: 'Photography pending — owner has chassis in hand',
  },
  {
    id: 'showcase',
    name: 'Showcase Configuration',
    variant: 'LANCOOL 217 INF — Infinity Mirror',
    tagline: 'For trade displays, Chamber events, and demonstrations',
    accent: 'from-indigo-900/20 to-violet-900/20',
    badge: 'Demo & Events',
    description:
      'The infinity mirror front panel creates a depth-of-field visual that draws foot traffic at trade events and Chamber of commerce meetings. The same professional internals, wrapped in a package that starts conversations. This is the unit that opens doors — the other two close.',
    specs: [
      { label: 'Chassis', value: 'Lian-Li LANCOOL 217 INF (Infinity Mirror)' },
      { label: 'Form Factor', value: 'ATX mid-tower, 380mm GPU clearance' },
      { label: 'Target GPU', value: 'RTX 4090 / 5090 (all variants)' },
      { label: 'Cooling', value: '3 pre-installed ARGB fans (170mm x2, 140mm x1)' },
      { label: 'Mobo Support', value: 'ATX / mATX / ITX' },
      { label: 'Special', value: 'Tempered glass infinity mirror front panel' },
      { label: 'Aesthetic', value: 'ARGB lighting, mirror depth effect, black steel' },
    ],
    useCases: ['Trade shows', 'Chamber events', 'Client demonstrations', 'Office lobby display'],
    photoNote: 'Photography pending — owner has chassis in hand',
  },
];

const compactBuilds = [
  {
    name: 'B4-mATX',
    variant: 'Compact — 21.3L',
    description: 'Primary chassis for compact Local Vault deployments. Fits RTX 4090/5090 FE with margin. Wood front option available.',
    badge: 'Primary (Compact)',
    specs: '21.3L | 358mm GPU | 4-slot | mATX/ITX | $69.99 USD MSRP',
  },
  {
    name: 'A3-mATX',
    variant: 'Compact — 26.3L',
    description: 'Alternate for maximum GPU clearance (415mm). Fits every AIB card. Better thermals out of the box. Dan Cases collaboration.',
    badge: 'Alternate (Max GPU)',
    specs: '26.3L | 415mm GPU | 4-slot | mATX/ITX | ~$100-130 CAD',
  },
];
---

<Layout
  title="Reference Systems — elect-rix.tech"
  description="Local Vault reference builds in Lian-Li chassis. Professional on-premise AI infrastructure for regulated industries."
>
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pt-24 pb-16">
    <header class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-accent/10 text-accent-bright text-sm font-medium mb-6 border border-accent/20">
        <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
        Reference Systems
      </div>
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-4">
        Built with Lian-Li
      </h1>
      <p class="text-lg text-text-muted max-w-2xl mx-auto leading-relaxed">
        Every Local Vault is built inside a chassis chosen for professional deployment — not a gaming setup. These are our reference configurations.
      </p>
    </header>

    <!-- Build cards -->
    <div class="space-y-8 mb-16">
      {builds.map((build) => (
        <div class="rounded-xl border border-border bg-surface overflow-hidden">
          <!-- Header -->
          <div class={`bg-gradient-to-br ${build.accent} px-6 py-5 border-b border-border`}>
            <div class="flex items-start justify-between gap-4 flex-wrap">
              <div>
                <div class="text-xs font-semibold uppercase tracking-wider text-accent-bright mb-1">{build.badge}</div>
                <h2 class="text-2xl font-bold">{build.name}</h2>
                <p class="text-sm text-text-muted mt-1">{build.variant}</p>
              </div>
              <div class="text-right">
                <p class="text-sm text-text-muted italic">{build.tagline}</p>
              </div>
            </div>
          </div>

          <!-- Body -->
          <div class="p-6">
            <p class="text-text-muted leading-relaxed mb-6">{build.description}</p>

            <!-- Specs -->
            <div class="grid sm:grid-cols-2 gap-x-6 gap-y-2 mb-6">
              {build.specs.map((spec) => (
                <div class="flex justify-between gap-4 text-sm border-b border-border/50 pb-1.5">
                  <span class="text-text-muted shrink-0">{spec.label}</span>
                  <span class="text-text text-right font-medium">{spec.value}</span>
                </div>
              ))}
            </div>

            <!-- Use cases -->
            <div class="flex flex-wrap gap-2">
              {build.useCases.map((uc) => (
                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-accent/10 text-accent-bright border border-accent/20">
                  {uc}
                </span>
              ))}
            </div>

            <!-- Photo note -->
            <div class="mt-6 p-3 rounded-lg border border-dashed border-border text-sm text-text-muted text-center">
              📷 {build.photoNote}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Compact chassis section -->
    <div class="mb-16">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold tracking-tight mb-4">Compact Form Factor</h2>
        <p class="text-text-muted text-lg max-w-2xl mx-auto">
          For deployments where desk footprint matters — the B4-mATX and A3-mATX fit a 4090/5090 in under 27 litres.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 gap-6">
        {compactBuilds.map((cb) => (
          <div class="p-6 rounded-xl border border-border bg-surface">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-xl font-semibold">{cb.name}</h3>
              <span class="text-xs font-semibold uppercase tracking-wider px-2.5 py-1 rounded-full bg-accent/10 text-accent-bright border border-accent/20">
                {cb.badge}
              </span>
            </div>
            <p class="text-sm text-text-muted leading-relaxed mb-4">{cb.description}</p>
            <p class="text-sm text-text font-mono">{cb.specs}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Why Lian-Li -->
    <div class="p-6 rounded-xl border border-border bg-surface">
      <h2 class="text-2xl font-bold mb-4">Why These Chassis?</h2>
      <div class="space-y-3 text-text-muted leading-relaxed">
        <p>
          Lian-Li is a Taiwanese, privately-held company — not a PRC manufacturer, not a publicly-traded commodity brand. Their products are physical objects you own, with no telemetry, no cloud dependency, and no subscription model baked into the hardware.
        </p>
        <p>
          The LANCOOL 217 line carries PPLP certification for professional use, supports back-connect motherboards for ultra-clean cable routing, and ships with genuine wood accents that signal craftsmanship — not a gaming aesthetic. For law firms, healthcare clinics, and government offices, the visual language of the chassis matters as much as the thermal performance.
        </p>
        <p>
          The compact B4-mATX and A3-mATX bring the same build quality into a 21-26 litre footprint — small enough to sit on a desk as an appliance, not a server rack.
        </p>
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center mt-12">
      <a href="/contact" class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-accent text-white font-semibold hover:bg-accent-bright transition-colors">
        Discuss a Local Vault Deployment
      </a>
    </div>
  </section>
</Layout>